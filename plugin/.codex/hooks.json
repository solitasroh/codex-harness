{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_guard.py\"",
            "timeout": 20,
            "statusMessage": "위험 명령 검사(codex 이식 가드)"
          }
        ]
      }
    ]
  }
}
